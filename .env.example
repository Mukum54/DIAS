# ===========================================
# AIR DIASS — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.

# ── Database (PostgreSQL) ──────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/airdiass?schema=public"

# ── NextAuth ────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-here-using-openssl"

# ── Public URL (for QR codes, tracking links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Encryption (AES-256-GCM) ───────────────
# Must be at least 32 characters long (preferably 64 hex chars)
ENCRYPTION_KEY="32-byte-long-strong-secret-phrase!!"

# ── Google OAuth (optional — remove or leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email Service — Resend (optional)
RESEND_API_KEY="re_..."

# ── SMS Service — Twilio (optional)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="..."

# ── Redis — Upstash (optional)
UPSTASH_REDIS_REST_URL="..."
UPSTASH_REDIS_REST_TOKEN="..."

# ── File Storage — AWS S3 (optional — legacy)
AWS_S3_REGION="..."
AWS_S3_ACCESS_KEY_ID="..."
AWS_S3_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET_NAME="..."

# ── File Storage — Cloudflare R2 (optional — preferred)
CLOUDFLARE_R2_ENDPOINT="..."
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET_NAME="..."
CLOUDFLARE_R2_PUBLIC_URL="..."
